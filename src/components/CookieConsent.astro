---
// CookieConsent.astro - TITAN Design | GTM Consent Mode v2
---

<div id="nx-cookie-banner" class="fixed inset-0 z-[9999] pointer-events-none flex items-end sm:justify-start p-4 md:p-6 opacity-0 transition-opacity duration-500" style="display: none;">
  
  <div class="w-full sm:w-[420px] pointer-events-auto relative translate-y-4 transition-transform duration-500" id="nx-cookie-box">
    <!-- Gradient border wrapper -->
    <div class="rounded-2xl p-[1px] bg-gradient-to-b from-white/15 to-white/[0.03]">
      <div class="bg-black/95 backdrop-blur-2xl rounded-2xl p-6 md:p-8 relative overflow-hidden">

        <!-- Subtle ambient glow -->
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-primary/10 blur-[60px] rounded-full pointer-events-none"></div>

        <!-- Header -->
        <div class="mb-6 relative z-10">
          <div class="flex items-center gap-2.5 mb-3">
            <span class="size-1.5 bg-primary rounded-full shadow-[0_0_6px_#0ceaed] animate-pulse"></span>
            <span class="text-[9px] font-mono text-slate-500 uppercase tracking-widest">Consent Protocol</span>
          </div>
          <h3 class="font-display text-lg font-bold uppercase tracking-tight text-white mb-2">
            Kontrola nad danymi
          </h3>
          <p class="text-[11px] text-slate-500 leading-relaxed font-mono">
            Używamy cookies wyłącznie do analityki i marketingu NEXUS. Część plików jest niezbędna, aby panel i płatności działały stabilnie.
          </p>
        </div>

        <!-- Settings panel (hidden by default) -->
        <div id="nx-cookie-settings" class="mb-6 flex flex-col gap-3 border-t border-b border-white/5 py-5 hidden relative z-10">
          
          <!-- Necessary (always on) -->
          <div class="flex items-center justify-between">
            <div class="flex flex-col">
              <span class="text-xs font-display font-bold text-white uppercase tracking-wide">Niezbędne</span>
              <span class="text-[9px] font-mono text-slate-600 uppercase">Zawsze aktywne</span>
            </div>
            <div class="w-11 h-6 rounded-full bg-primary/20 border border-primary/30 flex items-center px-0.5 opacity-50 cursor-not-allowed">
              <div class="size-5 rounded-full bg-primary shadow-[0_0_6px_#0ceaed] translate-x-5 transition-transform duration-300"></div>
            </div>
          </div>

          <!-- Analytics toggle -->
          <div class="flex items-center justify-between">
            <div class="flex flex-col">
              <span class="text-xs font-display font-bold text-white uppercase tracking-wide">Analityczne</span>
              <span class="text-[9px] font-mono text-slate-600 uppercase">Statystyki i ruch</span>
            </div>
            <button type="button" id="nx-toggle-analytics" aria-label="Przełącz analityczne" role="switch" aria-checked="false"
              class="w-11 h-6 rounded-full border flex items-center px-0.5 transition-all duration-300 border-slate-700 bg-slate-900">
              <div id="nx-knob-analytics" class="size-5 rounded-full transition-all duration-300 translate-x-0 bg-slate-600"></div>
            </button>
          </div>

          <!-- Marketing toggle -->
          <div class="flex items-center justify-between">
            <div class="flex flex-col">
              <span class="text-xs font-display font-bold text-white uppercase tracking-wide">Marketingowe</span>
              <span class="text-[9px] font-mono text-slate-600 uppercase">Reklamy i retargeting</span>
            </div>
            <button type="button" id="nx-toggle-marketing" aria-label="Przełącz marketingowe" role="switch" aria-checked="false"
              class="w-11 h-6 rounded-full border flex items-center px-0.5 transition-all duration-300 border-slate-700 bg-slate-900">
              <div id="nx-knob-marketing" class="size-5 rounded-full transition-all duration-300 translate-x-0 bg-slate-600"></div>
            </button>
          </div>
        </div>

        <!-- Actions: Main -->
        <div id="nx-actions-main" class="flex flex-col gap-2.5 relative z-10">
          <button id="nx-btn-accept-all" class="w-full bg-primary text-bg-dark font-display font-bold uppercase text-[11px] tracking-widest py-3.5 rounded-full hover:brightness-110 hover:scale-[1.02] transition-all duration-300 neon-shadow-cyan">
            Zatwierdź Wszystkie
          </button>
          <div class="grid grid-cols-2 gap-2.5">
            <button id="nx-btn-necessary" class="border border-white/10 text-slate-400 font-mono uppercase text-[9px] tracking-widest py-3 rounded-full hover:border-primary/30 hover:text-primary transition-all duration-300">
              Tylko Niezbędne
            </button>
            <button id="nx-btn-show-settings" class="border border-white/10 text-slate-400 font-mono uppercase text-[9px] tracking-widest py-3 rounded-full hover:border-white/30 hover:text-white transition-all duration-300">
              Dostosuj
            </button>
          </div>
        </div>

        <!-- Actions: Settings -->
        <div id="nx-actions-settings" class="flex flex-col gap-2.5 relative z-10 hidden">
          <button id="nx-btn-save" class="w-full bg-primary text-bg-dark font-display font-bold uppercase text-[11px] tracking-widest py-3.5 rounded-full hover:brightness-110 hover:scale-[1.02] transition-all duration-300 neon-shadow-cyan">
            Zapisz Konfigurację
          </button>
          <button id="nx-btn-back" class="border border-white/10 text-slate-400 font-mono uppercase text-[9px] tracking-widest py-3 rounded-full hover:border-white/30 hover:text-white transition-all duration-300">
            Wróć
          </button>
        </div>

        <!-- Privacy link -->
        <div class="mt-5 text-center relative z-10">
          <a href="/polityka-prywatnosci" class="text-[9px] font-mono text-slate-600 hover:text-primary uppercase tracking-widest transition-colors">
            Polityka Prywatności
          </a>
        </div>

      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    var COOKIE_NAME = 'nx_consent';
    var REVISION = 1;

    var prefs = { necessary: true, analytics: false, marketing: false, functional: false };
    
    var banner = document.getElementById('nx-cookie-banner');
    var box = document.getElementById('nx-cookie-box');
    var settingsPanel = document.getElementById('nx-cookie-settings');
    var actionsMain = document.getElementById('nx-actions-main');
    var actionsSettings = document.getElementById('nx-actions-settings');
    
    var btnAnalytics = document.getElementById('nx-toggle-analytics');
    var knobAnalytics = document.getElementById('nx-knob-analytics');
    var btnMarketing = document.getElementById('nx-toggle-marketing');
    var knobMarketing = document.getElementById('nx-knob-marketing');

    function readCookie(name) {
      if (typeof document === 'undefined') return null;
      var all = document.cookie ? document.cookie.split('; ') : [];
      for (var i = 0; i < all.length; i++) {
        var idx = all[i].indexOf('=');
        var key = idx > -1 ? all[i].slice(0, idx) : all[i];
        if (key === name) return decodeURIComponent(idx > -1 ? all[i].slice(idx + 1) : '');
      }
      return null;
    }

    function writeCookie(name, value, days) {
      if (typeof document === 'undefined') return;
      days = days || 180;
      var expires = new Date(Date.now() + days * 864e5).toUTCString();
      var serialized = encodeURIComponent(typeof value === 'string' ? value : JSON.stringify(value));
      var cookie = name + '=' + serialized + '; Expires=' + expires + '; Path=/; SameSite=Lax';
      if (location.protocol === 'https:') cookie += '; Secure';
      document.cookie = cookie;
    }

    function parseExisting() {
      try {
        var raw = readCookie(COOKIE_NAME);
        if (!raw) return null;
        return JSON.parse(raw);
      } catch(e) { return null; }
    }

    function ensureDataLayer() {
      window.dataLayer = window.dataLayer || [];
      return window.dataLayer;
    }

    function gtagSafe() {
      var dl = ensureDataLayer();
      var g = window.gtag || function() { dl.push(arguments); };
      g.apply(null, arguments);
    }

    function pushDL(obj) { ensureDataLayer().push(obj); }

    function pushConsentUpdate(analytics, marketing, functional) {
      gtagSafe('consent', 'update', {
        analytics_storage: analytics ? 'granted' : 'denied',
        ad_storage: marketing ? 'granted' : 'denied',
        ad_user_data: marketing ? 'granted' : 'denied',
        ad_personalization: marketing ? 'granted' : 'denied',
        functionality_storage: functional ? 'granted' : 'denied',
        personalization_storage: functional ? 'granted' : 'denied'
      });
      pushDL({
        event: 'consent_update',
        analytics_storage: analytics ? 'granted' : 'denied',
        ad_storage: marketing ? 'granted' : 'denied',
        ad_user_data: marketing ? 'granted' : 'denied',
        ad_personalization: marketing ? 'granted' : 'denied'
      });
    }

    function storeCookie() {
      var cats = [];
      if (prefs.analytics) cats.push('analytics');
      if (prefs.marketing) cats.push('marketing');
      if (prefs.functional) cats.push('functional');
      writeCookie(COOKIE_NAME, { stamp: 'nexus-titan', necessary: true, categories: cats, rev: REVISION });
    }

    function hideBanner() {
      banner.classList.remove('opacity-100');
      box.classList.remove('translate-y-0');
      setTimeout(function() { banner.style.display = 'none'; }, 500);
    }

    function showBanner() {
      banner.style.display = 'flex';
      banner.getBoundingClientRect();
      banner.classList.add('opacity-100');
      box.classList.add('translate-y-0');
    }

    function updateToggles() {
      // Analytics
      if (prefs.analytics) {
        btnAnalytics.className = 'w-11 h-6 rounded-full border flex items-center px-0.5 transition-all duration-300 border-primary/40 bg-primary/10';
        knobAnalytics.className = 'size-5 rounded-full transition-all duration-300 translate-x-5 bg-primary shadow-[0_0_6px_#0ceaed]';
        btnAnalytics.setAttribute('aria-checked', 'true');
      } else {
        btnAnalytics.className = 'w-11 h-6 rounded-full border flex items-center px-0.5 transition-all duration-300 border-slate-700 bg-slate-900';
        knobAnalytics.className = 'size-5 rounded-full transition-all duration-300 translate-x-0 bg-slate-600';
        btnAnalytics.setAttribute('aria-checked', 'false');
      }
      // Marketing
      if (prefs.marketing) {
        btnMarketing.className = 'w-11 h-6 rounded-full border flex items-center px-0.5 transition-all duration-300 border-primary/40 bg-primary/10';
        knobMarketing.className = 'size-5 rounded-full transition-all duration-300 translate-x-5 bg-primary shadow-[0_0_6px_#0ceaed]';
        btnMarketing.setAttribute('aria-checked', 'true');
      } else {
        btnMarketing.className = 'w-11 h-6 rounded-full border flex items-center px-0.5 transition-all duration-300 border-slate-700 bg-slate-900';
        knobMarketing.className = 'size-5 rounded-full transition-all duration-300 translate-x-0 bg-slate-600';
        btnMarketing.setAttribute('aria-checked', 'false');
      }
    }

    // Events
    document.getElementById('nx-btn-accept-all').addEventListener('click', function() {
      prefs = { necessary: true, analytics: true, marketing: true, functional: true };
      storeCookie();
      pushConsentUpdate(true, true, true);
      pushDL({ event: 'consent_initial_selection' });
      hideBanner();
    });

    document.getElementById('nx-btn-necessary').addEventListener('click', function() {
      prefs = { necessary: true, analytics: false, marketing: false, functional: false };
      storeCookie();
      pushConsentUpdate(false, false, false);
      pushDL({ event: 'consent_initial_selection' });
      hideBanner();
    });

    document.getElementById('nx-btn-show-settings').addEventListener('click', function() {
      settingsPanel.classList.remove('hidden');
      actionsMain.classList.add('hidden');
      actionsSettings.classList.remove('hidden');
      updateToggles();
    });

    document.getElementById('nx-btn-back').addEventListener('click', function() {
      settingsPanel.classList.add('hidden');
      actionsMain.classList.remove('hidden');
      actionsSettings.classList.add('hidden');
    });

    document.getElementById('nx-btn-save').addEventListener('click', function() {
      storeCookie();
      pushConsentUpdate(prefs.analytics, prefs.marketing, prefs.functional);
      pushDL({ event: 'consent_initial_selection' });
      hideBanner();
    });

    btnAnalytics.addEventListener('click', function() {
      prefs.analytics = !prefs.analytics;
      updateToggles();
    });

    btnMarketing.addEventListener('click', function() {
      prefs.marketing = !prefs.marketing;
      updateToggles();
    });

    // Init
    function init() {
      var existing = parseExisting();
      if (!existing || existing.rev !== REVISION) {
        setTimeout(showBanner, 800);
      } else {
        var cats = existing.categories || [];
        prefs = {
          necessary: true,
          analytics: cats.indexOf('analytics') !== -1,
          marketing: cats.indexOf('marketing') !== -1,
          functional: cats.indexOf('functional') !== -1
        };
        pushConsentUpdate(prefs.analytics, prefs.marketing, prefs.functional);
      }
    }

    init();

    // Global for footer "change cookies" link
    window.openCookiePreferences = function() {
      showBanner();
      document.getElementById('nx-btn-show-settings').click();
    };
  })();
</script>
