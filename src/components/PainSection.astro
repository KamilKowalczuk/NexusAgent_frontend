---
interface Props {
  data?: {
    oldWayTitle?: string;
    oldWayItems?: { title: string; description: string }[];
    titanWayTitle?: string;
    titanWayItems?: { title: string; description: string }[];
  };
}

const { data } = Astro.props;

const oldWayTitle = data?.oldWayTitle || 'The Old Way';
const oldWayItems = data?.oldWayItems || [
  {
    title: 'Expensive SDRs',
    description: '10,000 PLN/mc za pracownika, który spędza 70% czasu na ręcznym, wtórnym researchu i wklejaniu danych do CRM.',
  },
  {
    title: 'Generic Agencies',
    description: 'Szablonowe maile z generatorów, które trafiają prosto do spamu przez brak kontekstu i tanie sztuczki socjotechniczne.',
  },
];

const titanWayTitle = data?.titanWayTitle || 'The Titan Way';
const titanWayItems = data?.titanWayItems || [
  {
    title: 'Hyper-Personalization',
    description: 'Wstrzykujemy unikalne fakty wyciągnięte z case studies i wpisów na blogu na ułamek sekundy przed wysłaniem maila.',
  },
  {
    title: 'Autonomiczne Domykanie',
    description: 'System zdejmuje z Ciebie czarną robotę. Skupiasz się tylko na leadach, które powiedziały "TAK, porozmawiajmy".',
  },
];
---

<section class="max-w-7xl mx-auto px-8 py-32 w-full" id="pain">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- The Old Way -->
    <div class="fade-up">
      <div
        class="rounded-3xl p-[1px] bg-gradient-to-b from-red-500/40 to-red-900/10 hover:-translate-y-2 transition-transform duration-700 h-full"
      >
        <div
          class="w-full h-full bg-black/90 p-10 md:p-14 rounded-3xl relative overflow-hidden flex flex-col group"
        >
          <div
            class="absolute inset-0 bg-red-500/[0.02] group-hover:bg-red-500/[0.05] transition-colors duration-700 pointer-events-none"
          >
          </div>
          <div
            class="absolute top-0 right-0 p-8 opacity-10 group-hover:opacity-20 transition-opacity duration-700"
          >
            <span class="material-symbols-outlined text-[120px] text-red-500"
              >trending_down</span
            >
          </div>

          <div class="relative z-10 flex-1 flex flex-col">
            <h3
              class="font-display text-3xl md:text-4xl font-bold uppercase mb-8 text-red-500 drop-shadow-lg"
            >
              {oldWayTitle}
            </h3>

            <ul class="space-y-8 flex-1">
              {oldWayItems.map((item) => (
                <li class="flex items-start gap-4">
                  <span class="material-symbols-outlined text-red-500 mt-1">block</span>
                  <div>
                    <h4 class="font-bold text-lg text-white mb-1">{item.title}</h4>
                    <p class="text-slate-400 text-sm leading-relaxed">{item.description}</p>
                  </div>
                </li>
              ))}
            </ul>

            <!-- Link commented out intentionally as in original code -->
          </div>
        </div>
      </div>
    </div>

    <!-- The Titan Way -->
    <div class="fade-up" style="transition-delay: 150ms;">
      <div
        class="rounded-3xl p-[1px] bg-gradient-to-b from-primary/50 to-primary/10 hover:-translate-y-2 transition-transform duration-700 h-full"
      >
        <div
          class="w-full h-full bg-black/90 p-10 md:p-14 rounded-3xl relative overflow-hidden flex flex-col group"
        >
          <div
            class="absolute inset-0 bg-primary/[0.02] group-hover:bg-primary/[0.05] transition-colors duration-700 pointer-events-none"
          >
          </div>
          <div
            class="absolute top-0 right-0 p-8 opacity-10 group-hover:opacity-20 transition-opacity duration-700"
          >
            <span class="material-symbols-outlined text-[120px] text-primary"
              >rocket_launch</span
            >
          </div>

          <div class="relative z-10 flex-1 flex flex-col">
            <h3
              class="font-display text-3xl md:text-4xl font-bold uppercase mb-8 text-primary drop-shadow-lg"
            >
              {titanWayTitle}
            </h3>

            <ul class="space-y-8 flex-1">
              {titanWayItems.map((item) => (
                <li class="flex items-start gap-4">
                  <span class="material-symbols-outlined text-primary mt-1">check_circle</span>
                  <div>
                    <h4 class="font-bold text-lg text-white mb-1">{item.title}</h4>
                    <p class="text-slate-400 text-sm leading-relaxed">{item.description}</p>
                  </div>
                </li>
              ))}
            </ul>

            <!-- Link commented out intentionally as in original code -->
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
