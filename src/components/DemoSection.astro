---
import TerminalDemo from './TerminalDemo.svelte';

interface Props {
  data?: {
    badge?: string;
    headline?: string;
    inputLabelUrl?: string;
    inputLabelIndustry?: string;
  };
}

const { data } = Astro.props;

const badge = data?.badge || 'LIVE REVENUE_ATTACK_SIMULATION';
const headline =
  data?.headline ||
  'Wpisz adres konkurenta. Zobacz, jak wielu ich klientów możesz przejąć.';
const inputLabelUrl =
  data?.inputLabelUrl || 'URL firmy, z którą dziś przegrywasz kontrakty';
const inputLabelIndustry = data?.inputLabelIndustry || 'Branża / segment (opcjonalnie)';
---

<TerminalDemo 
  client:visible
  badge={badge} 
  headline={headline} 
  inputLabelUrl={inputLabelUrl} 
  inputLabelIndustry={inputLabelIndustry} 
/>
