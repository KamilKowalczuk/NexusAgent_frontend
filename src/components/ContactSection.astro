---
import ContactForm from './ContactForm.svelte';

interface Props {
  data?: {
    badge?: string;
    headline?: string;
    subtitle?: string;
  };
}

const { data } = Astro.props;

const badge = data?.badge || 'Onboarding';
const headline =
  data?.headline || 'Skonfiguruj NEXUS pod swój lejek sprzedaży';
const subtitle =
  data?.subtitle ||
  'Podaj parametry biznesu, marżę i profil idealnego klienta. Wrócimy z konkretnym planem kampanii i prognozą przychodów – bez płacenia za discovery call.';
---

<section class="max-w-7xl mx-auto px-4 sm:px-8 py-32 w-full relative" id="contact">
  <!-- Ambient glow -->
  <div class="absolute top-[30%] right-0 w-[400px] h-[400px] bg-accent/5 blur-[150px] rounded-full pointer-events-none"></div>

  <div class="text-center mb-16 fade-up relative z-10">
    <span class="inline-block px-3 py-1 bg-primary/10 border border-primary/20 rounded-full text-[10px] text-primary font-mono uppercase tracking-widest mb-6">{badge}</span>
    <h2 class="font-display text-4xl md:text-6xl font-bold uppercase tracking-tighter mb-6 glitch" data-text={headline}>{headline}</h2>
    <p class="text-slate-400 max-w-xl mx-auto font-light text-base">{subtitle}</p>
  </div>

  <div class="fade-up relative z-10">
    <!-- W przyszłości wypadałoby przenieść np inputy jako propsy do formularza, ale narazie opieramy się na Svelte i to jest ok -->
    <ContactForm client:visible />
  </div>
</section>
