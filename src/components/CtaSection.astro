---
interface Props {
  data?: {
    headline?: string;
    subtitle?: string;
    buttonText?: string;
    buttonUrl?: string;
    systemStatus?: string;
  };
}

const { data } = Astro.props;

// Pobierz aktualne sloty z Payload (tak samo jak Header i PricingSection)
let totalSlots = 10;
let usedSlots = 0;
try {
  const PAYLOAD_URL = import.meta.env.PAYLOAD_URL || 'http://127.0.0.1:3000';
  const res = await fetch(`${PAYLOAD_URL}/api/globals/landing-page?depth=0`, {
    signal: AbortSignal.timeout(2000),
  });
  if (res.ok) {
    const d = await res.json();
    totalSlots = d?.slots?.totalSlots ?? 10;
    usedSlots = d?.slots?.usedSlots ?? 0;
  }
} catch (_) {
  // Fallback to defaults
}

const availableSlots = Math.max(0, totalSlots - usedSlots);

const headline = data?.headline || 'Ostatni krok przed skalowaniem.';
// Jeśli Payload ma własny subtitle, użyj go; jeśli nie, generuj z żywymi danymi
const subtitle = data?.subtitle ||
  `Zostało tylko <span class="text-white font-bold underline decoration-primary">${availableSlots} z ${totalSlots} dostępnych slotów</span> na ten miesiąc. Zamknięcie naboru nastąpi automatycznie po wypełnieniu miejsc.`;
const buttonText = data?.buttonText || 'Zarezerwuj Swoje Miejsce';
const buttonUrl = data?.buttonUrl || '#pricing';
const systemStatus = data?.systemStatus || `System status: Active | Sloty: ${usedSlots}/${totalSlots} | Slot verification: Online`;
---

<section class="max-w-7xl mx-auto px-8 py-32 w-full fade-up">
  <div class="glass p-20 rounded-[40px] border-primary/20 text-center relative overflow-hidden group">
    <div class="absolute inset-0 bg-primary/5 group-hover:bg-primary/10 transition-all duration-700"></div>
    <!-- Floating ambient orb -->
    <div class="absolute bottom-0 right-[10%] w-[300px] h-[300px] bg-accent/10 blur-[120px] rounded-full pointer-events-none float-slow-reverse"></div>

    <div class="relative z-10 max-w-2xl mx-auto">
      <h2 class="font-display text-5xl md:text-7xl font-bold uppercase tracking-tight mb-8 glitch" data-text={headline}>{headline}</h2>
      <p class="text-xl text-slate-400 mb-12" set:html={subtitle}>
      </p>
      <a href={buttonUrl} class="inline-block bg-primary text-bg-dark font-display font-bold text-lg uppercase px-16 py-8 rounded-full hover:scale-105 transition-all duration-300 neon-shadow-cyan">
        {buttonText}
      </a>
      <div class="mt-8 font-mono text-[11px] text-slate-600 uppercase tracking-widest auto-glitch">
        {systemStatus}
      </div>
    </div>
  </div>
</section>
