---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ThankYouCard from '../components/ThankYouCard.svelte';
---

<Layout
  meta={{
    title: 'Dziękujemy – NEXUS Agent',
    description:
      'Subskrypcja NEXUS została aktywowana. Każdy kolejny dzień kampanii ma dostarczać mierzalne leady, nie wymówki.',
  }}
>
  <Header />

  <main class="min-h-screen flex flex-col items-center justify-center px-8 py-32 text-center relative overflow-hidden">

    <!-- Ambient glows -->
    <div class="absolute top-1/4 left-1/4 w-[600px] h-[600px] bg-green-500/5 blur-[180px] rounded-full pointer-events-none"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-primary/5 blur-[150px] rounded-full pointer-events-none"></div>

    <ThankYouCard client:only="svelte" />

  </main>

  <Footer />
</Layout>
