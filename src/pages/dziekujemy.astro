---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const emailsParam = Astro.url.searchParams.get('emails') || '20';
const emails = Math.max(10, Math.min(100, parseInt(emailsParam)));
const price = 1999 + Math.max(0, emails - 20) * 25;
---

<Layout meta={{ title: 'Dziękujemy – NEXUS Agent', description: 'Twoja subskrypcja NEXUS Agent została aktywowana.' }}>
  <Header />

  <main class="min-h-screen flex flex-col items-center justify-center px-8 py-32 text-center relative overflow-hidden">

    <!-- Ambient glows -->
    <div class="absolute top-1/4 left-1/4 w-[600px] h-[600px] bg-green-500/5 blur-[180px] rounded-full pointer-events-none"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-primary/5 blur-[150px] rounded-full pointer-events-none"></div>

    <!-- Success card -->
    <div class="max-w-2xl w-full relative z-10">
      <div class="rounded-3xl p-[1px] bg-gradient-to-b from-green-500/50 to-green-900/10 mb-12">
        <div class="bg-black/90 rounded-3xl p-12 md:p-16">

          <!-- Pulsing dot -->
          <span class="relative flex h-6 w-6 mx-auto mb-10">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-6 w-6 bg-green-500 shadow-[0_0_20px_#22c55e]"></span>
          </span>

          <div class="inline-block px-4 py-1.5 bg-green-500/10 border border-green-500/30 rounded-full text-[10px] font-mono text-green-400 uppercase tracking-widest mb-6">
            System aktywny
          </div>

          <h1 class="font-display text-4xl md:text-5xl font-bold uppercase tracking-tighter text-white mb-6">
            NEXUS Agent<br />
            <span class="text-green-400">Uruchomiony</span>
          </h1>

          <p class="text-slate-400 text-sm leading-relaxed mb-10 max-w-md mx-auto">
            Twoja subskrypcja została aktywowana. Skontaktujemy się z Tobą w ciągu
            <strong class="text-white">24 godzin</strong>, aby przeprowadzić onboarding
            i uruchomić kampanię.
          </p>

          <!-- Plan summary -->
          <div class="glass rounded-2xl p-6 border border-white/5 text-left mb-10">
            <div class="flex justify-between items-center text-xs font-mono uppercase text-slate-500 mb-4 tracking-widest">
              <span>Twój plan</span>
              <span class="text-green-400">Aktywny</span>
            </div>
            <div class="flex justify-between items-end">
              <div>
                <div class="text-white font-bold">{emails} maili / dzień</div>
                <div class="text-slate-500 text-xs mt-1">24/7 Autonomiczna Praca</div>
              </div>
              <div class="text-right">
                <div class="text-3xl font-display font-bold text-primary">{price.toLocaleString('pl-PL')} zł</div>
                <div class="text-slate-500 text-xs mt-1">/ miesiąc</div>
              </div>
            </div>
          </div>

          <!-- Next steps -->
          <div class="space-y-3 text-left mb-10">
            {[
              'Potwierdzenie subskrypcji zostało wysłane na Twój email',
              'Nasz zespół skontaktuje się z Tobą w ciągu 24h',
              'Konsultacja onboardingowa – definiujemy grupę docelową',
              'NEXUS rusza pełną mocą w ciągu 14 dni',
            ].map((step, i) => (
              <div class="flex items-center gap-4">
                <div class="size-6 rounded-full bg-green-500/10 border border-green-500/30 flex items-center justify-center shrink-0">
                  <span class="text-green-400 text-[10px] font-mono font-bold">{i + 1}</span>
                </div>
                <span class="text-slate-300 text-sm">{step}</span>
              </div>
            ))}
          </div>

          <a
            href="/"
            class="inline-flex items-center gap-3 border border-white/10 text-slate-400 font-mono uppercase text-[10px] tracking-widest px-8 py-4 rounded-full hover:border-primary/30 hover:text-primary transition-all duration-300"
          >
            <span class="material-symbols-outlined text-sm">arrow_back</span>
            Wróć na stronę główną
          </a>
        </div>
      </div>

      <!-- Status bar -->
      <div class="font-mono text-[9px] text-slate-600 uppercase tracking-widest">
        STATUS SYSTEMU: AKTYWNY | NEXUS AGENT v2.4 | SLOT VERIFIED ✓
      </div>
    </div>
  </main>

  <Footer />
</Layout>
