---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import OnboardingFlow from '../../components/OnboardingFlow.svelte';

const { token } = Astro.params;

if (!token) {
  return Astro.redirect('/');
}

let payloadData = null;
try {
  const PAYLOAD_URL = import.meta.env.PAYLOAD_URL || 'http://127.0.0.1:3000';
  const res = await fetch(`${PAYLOAD_URL}/api/globals/landing-page?depth=1`);
  if (res.ok) payloadData = await res.json();
} catch {
  // fallback do domyślnych wartości headera
}
---

<Layout
  meta={{
    title: 'Konfiguracja NEXUS – Brief Wdrożeniowy',
    description: 'Wypełnij brief wdrożeniowy, aby NEXUS mógł rozpocząć autonomiczną kampanię cold email B2B dla Twojej firmy.',
  }}
>
  <Header data={payloadData?.header} slots={payloadData?.slots} />

  <main class="min-h-screen flex flex-col items-center justify-center px-4 py-24 relative overflow-hidden">

    <!-- Ambient glows -->
    <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-primary/8 blur-[160px] rounded-full pointer-events-none"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-accent/8 blur-[140px] rounded-full pointer-events-none"></div>

    <OnboardingFlow client:only="svelte" token={token} />

  </main>

  <Footer data={payloadData?.footer} />
</Layout>
